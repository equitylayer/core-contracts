{
  "filter_paths": "lib/|node_modules/|test/|script/|src/mocks/|src/zk-verifiers/",
  "solc_remaps": [
    "@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/",
    "@openzeppelin/contracts-upgradeable/=lib/openzeppelin-contracts-upgradeable/contracts/",
    "@eas/contracts/=lib/eas-contracts/contracts/",
    "lib/RuleEngine:CMTAT/=lib/RuleEngine/lib/CMTAT/contracts/",
    "CMTAT/contracts/=lib/CMTAT/contracts/",
    "CMTAT/interfaces/=lib/CMTAT/contracts/interfaces/",
    "RuleEngine/interfaces/=lib/RuleEngine/src/interfaces/",
    "RuleEngine/modules/=lib/RuleEngine/src/modules/",
    "RuleEngine/src/=lib/RuleEngine/src/",
    "RuleEngine/=lib/RuleEngine/",
    "Rules/=lib/Rules/src/",
    "OZ/=lib/RuleEngine/lib/openzeppelin-contracts/contracts/",
    "forge-std/=lib/forge-std/src/",
    "erc4626-tests/=lib/openzeppelin-contracts-upgradeable/lib/erc4626-tests/",
    "halmos-cheatcodes/=lib/openzeppelin-contracts-upgradeable/lib/halmos-cheatcodes/src/",
    "openzeppelin-contracts-upgradeable/=lib/openzeppelin-contracts-upgradeable/",
    "openzeppelin-contracts/=lib/openzeppelin-contracts/",
    "@fhenixprotocol/cofhe-contracts/=node_modules/@fhenixprotocol/cofhe-contracts/",
    "@cofhe/mock-contracts/=node_modules/@cofhe/mock-contracts/contracts/",
    "hardhat/=lib/forge-std/src/",
    "eas-contracts/=lib/eas-contracts/contracts/"
  ],
  "solc_args": "--base-path . --include-path lib --include-path node_modules --evm-version cancun --via-ir --optimize --optimize-runs 200",
  "detectors_to_exclude": "conformance-to-solidity-naming-conventions,assembly",
  "exclude_dependencies": true,
  "exclude_informational": false,
  "exclude_low": false,
  "compile_force_framework": "solc",
  "skip_clean": true
}
